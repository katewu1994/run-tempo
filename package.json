{
  "name": "run-tempo",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "setup:youtube": "npm --prefix backend run setup:youtube",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "test:bpm": "node scripts/run-bpm-tests.mjs",
    "test:backend": "npm --prefix backend test",
    "test:export": "node scripts/run-export-tests.mjs",
    "test:multi": "node scripts/run-multi-track-tests.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "essentia.js": "^0.1.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.6.3",
    "vite": "^6.4.3"
  }
}
